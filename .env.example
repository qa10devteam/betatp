# atpbet.io — Environment Configuration
# Copy to .env and fill in your values

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:betatp2026@localhost:5432/betatp

# ── Redis (optional — for caching and Celery) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-in-production-32chars-min
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── Paths ──────────────────────────────────────────────────────────────────────
MODELS_PATH=/home/ubuntu/betatp/models
COUPONS_PATH=/home/ubuntu/betatp/coupons
TML_DATABASE_PATH=/home/ubuntu/TML-Database

# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=development    # development | staging | production

# ── Telegram (optional — for daily coupon push) ────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHANNEL_ID=@your_channel_or_-1001234567890

# ── Model settings ─────────────────────────────────────────────────────────────
EDGE_THRESHOLD=0.04        # min edge for value bets (default: 4%)
MAX_KELLY_FRACTION=0.05    # max Kelly stake fraction (default: 5%)
COUPON_BUDGET=15.0         # default coupon budget in PLN
