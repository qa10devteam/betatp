    selDesc:'<span class="v">Mecz trwa 3 sety</span> — model P=56% vs implied P=40.8% z kursem 2.45. Monfils historycznie 61% meczow w 3 setach na trawie. Gojo wzrosty w 2026. Edge +37.2%.',
    odds:2.45,pM:.56,pB:.408,edge:37.2,surf:'grass',tour:'Wimbledon 2026',
    rar:'jackpot',conf:.81,
    reasons:[{txt:'Monfils 61% meczow w 3 setach na trawie',pos:true},{txt:'Gojo wzrostowy trend na trawie (2026)',pos:true},{txt:'Avg dlugosc meczow Monfilsa: 2h18min',pos:true},{txt:'Monfils moze ograniczyc serwis (odcisk)',pos:false}],
    imgUrl:'https://v3b.fal.media/files/b/0a9fe189/2lgVtIxPEOb0lHDTnsBPx_P5m5rzOS.png'}
];

const MATCHES=[
  {id:1,p1:'Carlos Alcaraz',p2:'Taylor Fritz',t:'12:00',w:[{s:'Alcaraz',o:1.38,e:-3},{s:'Fritz',o:3.20,e:31.6}],h:[{s:'Alcaraz -1.5',o:1.62,e:5.4},{s:'Fritz +1.5',o:2.20,e:9.2}],to:[{s:'Pod 2.5',o:1.72,e:7.1},{s:'Nad 2.5',o:2.00,e:4.3}]},
  {id:2,p1:'Jannik Sinner',p2:'Holger Rune',t:'13:30',w:[{s:'Sinner',o:1.55,e:8.3},{s:'Rune',o:2.50,e:6.2}],h:[{s:'Sinner -1.5',o:2.10,e:3.1},{s:'Rune +1.5',o:1.70,e:12.8}],to:[{s:'Pod 2.5',o:1.80,e:9.6},{s:'Nad 2.5',o:1.95,e:3.2}]},
  {id:3,p1:'Djokovic',p2:'Shapovalov',t:'14:00',w:[{s:'Djokovic',o:1.40,e:5.2},{s:'Shapovalov',o:3.00,e:12.4}],h:[{s:'Djok -1.5',o:1.90,e:6.8},{s:'Shap +1.5',o:1.80,e:8.4}],to:[{s:'Pod 2.5',o:1.65,e:4.2},{s:'Nad 2.5',o:2.10,e:7.1}]},
