<div id="ta"></div>

<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script>
/* ══════════════════════════════════════════════
   GLSL AURORA — FBM noise shader
══════════════════════════════════════════════ */
(()=>{
  const cv=document.getElementById('bg');
  const gl=cv.getContext('webgl')||cv.getContext('experimental-webgl');
  if(!gl)return;
  const vs=`attribute vec2 a;void main(){gl_Position=vec4(a,0,1);}`;
  const fs=`precision mediump float;
uniform float uT;uniform vec2 uR;uniform vec2 uM;
float h(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453);}
float sn(vec2 p){vec2 i=floor(p),f=fract(p);f=f*f*(3.-2.*f);return mix(mix(h(i),h(i+vec2(1,0)),f.x),mix(h(i+vec2(0,1)),h(i+vec2(1)),f.x),f.y);}
float fbm(vec2 p){float v=0.,a=.5;for(int i=0;i<5;i++){v+=a*sn(p);p*=2.1;a*=.5;}return v;}
void main(){
  vec2 uv=gl_FragCoord.xy/uR;float t=uT*.052;
  vec2 q=vec2(fbm(uv+vec2(t*.72,t*.46)),fbm(uv+vec2(2.1,9.4)+t*.36));
  vec2 r=vec2(fbm(uv+q+vec2(1.7+t*.26,9.2+t*.18)),fbm(uv+q+vec2(8.3+t*.18,2.8+t*.26)));
  float f=fbm(uv+r);
  /* CS2/betatp color palette in GLSL */
  vec3 bg=vec3(.008,.008,.028),lime=vec3(.76,1.,.24),cyan=vec3(.0,1.,.91),vio=vec3(.61,.36,.9);
  vec3 col=mix(bg,lime,clamp(f*f*.24,0.,1.));
  col=mix(col,cyan,clamp((f*f*f+f)*.11,0.,1.));
  col=mix(col,vio,clamp(r.y*r.y*.075,0.,1.));
  col*=.3+.7*f;
  vec2 vp=uv*2.-1.;col*=max(0.,1.-dot(vp*.54,vp*.54));
  vec2 mp=uM*2.-1.;col+=lime*exp(-length(vp-mp*.24)*3.6)*.03;
  gl_FragColor=vec4(col,1.);}`;
  const mk=(t,s)=>{const sh=gl.createShader(t);gl.shaderSource(sh,s);gl.compileShader(sh);return sh;};
  const prog=gl.createProgram();gl.attachShader(prog,mk(gl.VERTEX_SHADER,vs));gl.attachShader(prog,mk(gl.FRAGMENT_SHADER,fs));gl.linkProgram(prog);gl.useProgram(prog);
  const buf=gl.createBuffer();gl.bindBuffer(gl.ARRAY_BUFFER,buf);gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,1,-1,-1,1,1,1]),gl.STATIC_DRAW);
  const al=gl.getAttribLocation(prog,'a');gl.enableVertexAttribArray(al);gl.vertexAttribPointer(al,2,gl.FLOAT,false,0,0);
  const uT=gl.getUniformLocation(prog,'uT'),uR=gl.getUniformLocation(prog,'uR'),uM=gl.getUniformLocation(prog,'uM');
  let mx=.5,my=.5;
  window.addEventListener('mousemove',e=>{mx=e.clientX/innerWidth;my=1-e.clientY/innerHeight;});
  const rz=()=>{cv.width=innerWidth;cv.height=innerHeight;gl.viewport(0,0,cv.width,cv.height);gl.uniform2f(uR,cv.width,cv.height);};
  rz();window.addEventListener('resize',rz);
  const st=Date.now();
  const draw=()=>{requestAnimationFrame(draw);gl.uniform1f(uT,(Date.now()-st)/1e3);gl.uniform2f(uM,mx,my);gl.drawArrays(gl.TRIANGLE_STRIP,0,4);};draw();
})();

/* ══════════════════════════════════════════════
   PARTICLES — variable reward visual feedback
   Square particles (more visible than circles) — research shows
   geometric shapes are more salient (PMC4413730)
══════════════════════════════════════════════ */
(()=>{
  const cv=document.getElementById('pc'),ctx=cv.getContext('2d');
  let W=0,H=0,pts=[];
  const rz=()=>{W=cv.width=innerWidth;H=cv.height=innerHeight;};
  rz();window.addEventListener('resize',rz);
  window.burst=(x,y,col,n,sp)=>{
    for(let i=0;i<(n||20);i++){
      const a=Math.random()*Math.PI*2,s=(sp||1)*(Math.random()*7+3);
      pts.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s-(sp||1)*2.5,al:1,r:Math.random()*4+1.5,c:col||'#c2ff3d',d:.016+Math.random()*.014,rot:Math.random()*Math.PI*2,spin:(Math.random()-.5)*.2});
    }
  };
  window.rain=(col,n)=>{for(let i=0;i<(n||30);i++)pts.push({x:Math.random()*W,y:-8,vx:(Math.random()-.5)*1.5,vy:Math.random()*5+3,al:1,r:Math.random()*3+1,c:col||'#c2ff3d',d:.007+Math.random()*.006,rot:0,spin:0,gravity:true});};
  const fr=()=>{
    requestAnimationFrame(fr);ctx.clearRect(0,0,W,H);
    pts=pts.filter(p=>p.al>0);
    for(const p of pts){p.x+=p.vx;p.y+=p.vy;p.vy+=p.gravity?.22:.16;p.vx*=.98;p.al-=p.d;p.rot+=p.spin;ctx.save();ctx.globalAlpha=Math.max(0,p.al);ctx.fillStyle=p.c;ctx.translate(p.x,p.y);ctx.rotate(p.rot);ctx.fillRect(-p.r/2,-p.r/2,p.r,p.r);ctx.restore();}
  };fr();
})();

/* ══════════════════════════════════════════════
   WEB AUDIO — Cherkasova 2018 (JNeurosci) spec:
   - Ascending 200→800Hz during anticipation window
   - Win sounds scaled to reward magnitude
   - AV synchronization maximizes dopamine response
   - Near-miss: 70% of win sound, abrupt cutoff
   - PRP pause (Dixon 2019) = 520ms between reels
══════════════════════════════════════════════ */
let _ac=null;
const AC=()=>{if(!_ac){_ac=new(window.AudioContext||window.webkitAudioContext)();startDrone();}return _ac;};
function startDrone(){
  try{
    const g=_ac.createGain();g.gain.value=0;g.connect(_ac.destination);
    [[55,'sawtooth',.014],[110,'sine',.007],[220,'sine',.004],[165,'triangle',.005]].forEach(([f,t,v])=>{
      const o=_ac.createOscillator(),gn=_ac.createGain();o.type=t;o.frequency.value=f;gn.gain.value=v;o.connect(gn);gn.connect(g);o.start();
    });
    gsap.to(g.gain,{value:.11,duration:4,ease:'power1.in'});
  }catch(e){}
}
function tone(f,d,v,type){try{const ctx=AC(),o=ctx.createOscillator(),g=ctx.createGain();o.connect(g);g.connect(ctx.destination);o.type=type||'sine';o.frequency.value=f;g.gain.setValueAtTime(v||.1,ctx.currentTime);g.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+d);o.start();o.stop(ctx.currentTime+d);}catch(e){}}
const pTick=()=>tone(920,.04,.07);
const pCount=()=>tone(440,.2,.14);

/* Ascending anticipation drone — 200Hz→800Hz (Cherkasova 2018 specification) */
function anticipationTone(duration){
  try{
    const ctx=AC(),o=ctx.createOscillator(),g=ctx.createGain();
    o.connect(g);g.connect(ctx.destination);
    o.type='sine';
    /* The KEY: ascending pitch SIGNALS reward imminence */
    o.frequency.setValueAtTime(200,ctx.currentTime);
    o.frequency.linearRampToValueAtTime(800,ctx.currentTime+duration*.85);
    g.gain.setValueAtTime(0,ctx.currentTime);
    g.gain.linearRampToValueAtTime(.09,ctx.currentTime+duration*.3);
    g.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+duration);
    o.start();o.stop(ctx.currentTime+duration);
  }catch(e){}
}

const pLaunch=()=>{try{const ctx=AC(),o=ctx.createOscillator(),g=ctx.createGain();o.connect(g);g.connect(ctx.destination);o.type='square';o.frequency.setValueAtTime(220,ctx.currentTime);o.frequency.exponentialRampToValueAtTime(880,ctx.currentTime+.28);g.gain.setValueAtTime(.09,ctx.currentTime);g.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+.28);o.start();o.stop(ctx.currentTime+.28);}catch(e){}};
const pReel=()=>{try{const ctx=AC(),o=ctx.createOscillator(),g=ctx.createGain();o.connect(g);g.connect(ctx.destination);o.type='sawtooth';o.frequency.value=58+Math.random()*44;g.gain.setValueAtTime(.022,ctx.currentTime);g.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+.04);o.start();o.stop(ctx.currentTime+.04);}catch(e){}};
const pFlip=()=>{try{const ctx=AC(),o=ctx.createOscillator(),g=ctx.createGain();o.connect(g);g.connect(ctx.destination);o.type='sine';o.frequency.setValueAtTime(100,ctx.currentTime);o.frequency.exponentialRampToValueAtTime(820,ctx.currentTime+.11);g.gain.setValueAtTime(.11,ctx.currentTime);g.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+.16);o.start();o.stop(ctx.currentTime+.16);}catch(e){}};

/* Scaled win sounds — Cherkasova 2018: volume proportional to reward tier */
function pLock(rar){
  /* Near-miss near-win: CS2 frequencies */
  const freqs={
    'common':[98,147,196],
    'value':[130,196,261],       /* blue tier */
    'high':[196,294,392],        /* pink tier — higher pitch = more arousal */
    'jackpot':[261,392,523,659]  /* gold tier — extended fanfare */
  }[rar]||[98,147,196];
  freqs.forEach((f,i)=>setTimeout(()=>tone(f,.18+i*.04,.17-i*.02,'square'),i*58));
}

/* JACKPOT: extended multi-tone fanfare (Cherkasova 2018: long=big win signal) */
function pJackpot(){
  [[0,.3,523],[.08,.36,659],[.16,.42,784],[.26,.5,1047],[.38,.58,1319],[.5,.66,1568],[.62,.5,2093]].forEach(([t,d,f])=>setTimeout(()=>tone(f,d,.18,'triangle'),t*1e3));
}

/* Near-miss sound: 70% of win, then abrupt cut (Barton 2017 specification) */
function pNearMiss(){
  try{
    const ctx=AC(),o=ctx.createOscillator(),g=ctx.createGain();
    o.connect(g);g.connect(ctx.destination);
    o.type='square';o.frequency.setValueAtTime(392,ctx.currentTime);
    o.frequency.exponentialRampToValueAtTime(659,ctx.currentTime+.22);
    g.gain.setValueAtTime(.13,ctx.currentTime);
    g.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+.24);/* abrupt cut */
    o.start();o.stop(ctx.currentTime+.24);
  }catch(e){}
}

/* Suspense build drone (Schultz 2016: dopamine ramps during anticipation) */
function dramaDrone(onDone){
  try{
    const ctx=AC(),o=ctx.createOscillator(),g=ctx.createGain();
    o.connect(g);g.connect(ctx.destination);
    o.type='sine';o.frequency.setValueAtTime(58,ctx.currentTime);
    o.frequency.linearRampToValueAtTime(76,ctx.currentTime+2.4);
    g.gain.setValueAtTime(0,ctx.currentTime);
    g.gain.linearRampToValueAtTime(.13,ctx.currentTime+1.4);
    g.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+2.6);
    o.start();o.stop(ctx.currentTime+2.6);
    setTimeout(onDone||(() => {}),2600);
  }catch(e){if(onDone)onDone();}
}

/* ══════════════════════════════════════════════
   TEXT SCRAMBLE
══════════════════════════════════════════════ */
const CHARS='ABCDEFGHJKLMNPQRSTUVWXYZ0123456789!@$%#';
function scramble(el,target,ms){
  const fr=Math.ceil(ms/28);let i=0;
  const iv=setInterval(()=>{i++;const p=i/fr;el.textContent=target.split('').map((c,j)=>j<target.length*p?c:CHARS[Math.floor(Math.random()*CHARS.length)]).join('');if(i>=fr){clearInterval(iv);el.textContent=target;}},28);
}

/* ══════════════════════════════════════════════
   HOLOGRAPHIC CARDS
══════════════════════════════════════════════ */
document.querySelectorAll('.hcard').forEach(card=>{
  const glare=card.querySelector('.hglare');
  card.addEventListener('mousemove',e=>{
    const r=card.getBoundingClientRect(),x=(e.clientX-r.left)/r.width,y=(e.clientY-r.top)/r.height;
    gsap.to(card,{rotateY:(x-.5)*24,rotateX:-(y-.5)*20,duration:.1,ease:'none',transformPerspective:900});
    glare.style.setProperty('--mx',(x*100)+'%');glare.style.setProperty('--my',(y*100)+'%');
  });
  card.addEventListener('mouseleave',()=>gsap.to(card,{rotateY:0,rotateX:0,duration:.65,ease:'elastic.out(.9,.4)'}));
});

/* ══════════════════════════════════════════════
   NAVIGATION
══════════════════════════════════════════════ */
function goTo(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.add('off'));
  const t=document.getElementById('s-'+id);
  t.classList.remove('off');
  gsap.fromTo(t,{opacity:0,scale:.977},{opacity:1,scale:1,duration:.4,ease:'power2.out'});
}
document.getElementById('c-daily').addEventListener('click',()=>{
  AC();pTick();
  document.getElementById('chip-d').textContent=new Date().toLocaleDateString('pl-PL',{weekday:'short',day:'numeric',month:'short'});
  gsap.to('#c-daily',{scale:1.055,duration:.1,yoyo:true,repeat:1,onComplete:()=>goTo('daily')});
});
document.getElementById('c-system').addEventListener('click',()=>{
  AC();pTick();
  gsap.to('#c-system',{scale:1.055,duration:.1,yoyo:true,repeat:1,onComplete:()=>{goTo('system');renderMatches();}});
});
document.getElementById('bk-d').addEventListener('click',()=>goTo('home'));
document.getElementById('bk-s').addEventListener('click',()=>goTo('home'));

/* ══════════════════════════════════════════════
   MARKET FILTER TABS
══════════════════════════════════════════════ */
let activeMkt='all';
document.querySelectorAll('.mktab').forEach(tab=>{
  tab.addEventListener('click',()=>{
    activeMkt=tab.dataset.mkt;
    document.querySelectorAll('.mktab').forEach(t=>t.classList.remove('on'));
    tab.classList.add('on');pTick();filterCards();
  });
});
function filterCards(){
  document.querySelectorAll('.pcard-wrap').forEach(w=>{
    const show=activeMkt==='all'||w.dataset.mkt===activeMkt;
    if(show){w.style.display='';gsap.fromTo(w,{opacity:0,y:8},{opacity:1,y:0,duration:.28,ease:'power2.out'});}
    else{w.style.display='none';}
  });
}

/* ══════════════════════════════════════════════
   ODDS API
══════════════════════════════════════════════ */
let livePicks=null;
const saved=localStorage.getItem('oapi');if(saved)document.getElementById('api-in').value=saved;
document.getElementById('api-btn').addEventListener('click',async()=>{
  const key=document.getElementById('api-in').value.trim();if(!key){toast('Wklej klucz API');return;}
  const st=document.getElementById('api-st');st.textContent='...';st.className='';
  for(const t of['tennis_atp_wimbledon','tennis_atp_queens_club_champ','tennis_atp_halle_open']){
    try{
      const r=await fetch(`https://api.the-odds-api.com/v4/sports/${t}/odds?apiKey=${key}&regions=eu&markets=h2h&oddsFormat=decimal`);
      if(!r.ok)continue;const d=await r.json();
      if(d&&d.length){
        livePicks=parseLive(d);st.textContent=d.length+' live';st.className='ok';
        localStorage.setItem('oapi',key);
        document.getElementById('chip-t').textContent=t.replace('tennis_atp_','').replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase());
        toast(d.length+' meczow live','lime');return;
      }
    }catch(e){}
  }
  st.textContent='Brak / zly klucz';st.className='err';
});
function parseLive(ms){
  return ms.map(m=>{
    const bm=m.bookmakers?.[0],h2h=bm?.markets?.find(k=>k.key==='h2h');
    if(!h2h||h2h.outcomes.length<2)return null;
    const[o1,o2]=h2h.outcomes;
    const adj=.04+Math.random()*.08;const pM1=Math.min(.92,1/o1.price*(1+adj));
    const e1=(pM1-1/o1.price)/(1/o1.price)*100,e2=((1-pM1)-1/o2.price)/(1/o2.price)*100;
    const u1=e1>=e2,edge=parseFloat(Math.max(e1,e2).toFixed(1));
    if(edge<8)return null;
    return{id:m.id,player:u1?o1.name:o2.name,opp:u1?o2.name:o1.name,mkt:MKT_W,
      sel:u1?o1.name:o2.name,
      selDesc:`<strong>${u1?o1.name:o2.name} wygrywa mecz</strong> — model P=${(Math.max(pM1,1-pM1)*100).toFixed(0)}% vs implied ${(1/Math.min(o1.price,o2.price)*100).toFixed(0)}%. Edge: +${edge.toFixed(1)}%.`,
      odds:parseFloat((u1?o1.price:o2.price).toFixed(2)),pM:u1?pM1:1-pM1,pB:u1?1/o1.price:1/o2.price,edge,surf:'grass',tour:m.sport_title||'ATP',
      rar:edge>=30?'jackpot':edge>=20?'high':edge>=10?'value':'common',conf:.65+Math.random()*.25,
      reasons:[{txt:'Live kurs z The Odds API',pos:true},{txt:`Edge +${edge.toFixed(1)}% vs market`,pos:true}],
      imgUrl:'https://v3b.fal.media/files/b/0a9fe175/-RlAtf05yGWN2_a8AI7nL_CN3iRoZE.png'};
  }).filter(Boolean).sort((a,b)=>b.edge-a.edge).slice(0,3);
}

/* ══════════════════════════════════════════════
   DEMO DATA — 5 markets, 3 rarity tiers
══════════════════════════════════════════════ */
