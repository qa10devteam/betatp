  {id:5,p1:'Zverev',p2:'Musetti',t:'15:30',w:[{s:'Zverev',o:1.65,e:3.8},{s:'Musetti',o:2.25,e:9.1}],h:[{s:'Zve -1.5',o:2.15,e:2.1},{s:'Mus +1.5',o:1.62,e:11.4}],to:[{s:'Pod 2.5',o:1.75,e:8.4},{s:'Nad 2.5',o:2.00,e:6.2}]},
  {id:6,p1:'Hurkacz',p2:'Norrie',t:'16:00',w:[{s:'Hurkacz',o:1.72,e:15.3},{s:'Norrie',o:2.15,e:2.1}],h:[{s:'Hurk -1.5',o:2.40,e:3.6},{s:'Norrie +1.5',o:1.78,e:21.1}],to:[{s:'Pod 2.5',o:1.60,e:6.4},{s:'Nad 2.5',o:2.20,e:8.7}]},
  {id:7,p1:'Tommy Paul',p2:'Dimitrov',t:'17:00',w:[{s:'Paul',o:2.00,e:11.2},{s:'Dimitrov',o:1.85,e:4.5}],h:[{s:'Paul +1.5',o:1.45,e:9.8},{s:'Dim -1.5',o:2.55,e:5.3}],to:[{s:'Pod 2.5',o:1.90,e:7.2},{s:'Nad 2.5',o:1.85,e:9.1}]},
  {id:8,p1:'Rublev',p2:'Tiafoe',t:'17:30',w:[{s:'Rublev',o:1.90,e:7.6},{s:'Tiafoe',o:1.90,e:8.9}],h:[{s:'Rub -1.5',o:2.50,e:3.2},{s:'Tia +1.5',o:1.52,e:13.4}],to:[{s:'Pod 2.5',o:1.80,e:11.4},{s:'Nad 2.5',o:2.00,e:6.7}]},
];

const POOL=['Alcaraz','Sinner','Djokovic','Medvedev','Fritz','Zverev','Rublev','Hurkacz','Paul','Murray','Norrie','Shapovalov','De Minaur','Musetti','Dimitrov','Tiafoe','Rune','Monfils','Bublik','Tsitsipas','Berrettini','Kyrgios','Ruud','Auger-A.'];
const MKT_ICONS={winner:'🏆',sets:'1️⃣',handicap:'±',total:'∑',score:'⚡'};
const RAR_LBL={common:'COMMON',value:'VALUE',high:'HIGH VALUE',jackpot:'JACKPOT'};
/* CS2 color system for slot reels */
const RAR_COLOR={common:'#78909c',value:'#4b69ff',high:'#d32ce6',jackpot:'#ffd700'};

/* ══════════════════════════════════════════════
   SLOT MACHINE — Near-miss OVERSHOOT (Clark 2009, Neuron)
   Research: near-miss that overshoots and returns is MORE
   motivating than stopping short (anterior insula activation)
   Overshoot amount: 2-3 items past final position
   Near-miss frequency: built into ~30% of spins
══════════════════════════════════════════════ */
const IH=80,NR=42;
function buildTrack(el,pick){
  el.innerHTML='';
  const pool=[...POOL].sort(()=>Math.random()-.5);
  for(let i=0;i<NR;i++){
    const d=document.createElement('div');d.className='ritem';
    const mktArr=[MKT_W,MKT_H,MKT_T,MKT_S,MKT_SC];
    d.innerHTML=`<div class="ri-n">${pool[i%pool.length]}</div><div class="ri-o">${(1.3+Math.random()*2.5).toFixed(2)}</div><div class="ri-m">${mktArr[i%5].icon}</div>`;
    el.appendChild(d);
  }
  const fin=document.createElement('div');fin.className='ritem';
  const col=RAR_COLOR[pick.rar]||RAR_COLOR.value;
  fin.innerHTML=`<div class="ri-n" style="color:var(--t1);font-weight:900">${pick.player.split(' ').pop()}</div><div class="ri-o" style="color:${col}">${pick.odds.toFixed(2)}</div><div class="ri-m" style="color:${col}">${pick.mkt.icon}</div>`;
  el.appendChild(fin);
}

/* NEAR-MISS OVERSHOOT IMPLEMENTATION (Clark 2009):
   1. Reel spins to final position
   2. OVERSHOOTS by 2 items past the target
   3. Slowly bounces back to final position
   4. This activates anterior insula (Z=3.63) same as wins */
function spinReel(tEl,rEl,pick,delay,onDone){
  const finalY=-(NR-1)*IH;
  const overshootY=finalY-IH*2.3; /* 2.3 items past final — Clark 2009 overshoot pattern */
  gsap.set(tEl,{y:0});
  setTimeout(()=>{
    let last=0,anticipationFired=false;
    gsap.to(tEl,{
      y:overshootY, /* STEP 1: spin to overshoot (past target) */
      duration:2.55,
      ease:'power4.out',
      onUpdate(){
        const n=Date.now();if(n-last>48){pReel();last=n;}
        /* Fire near-miss sound at 88% progress (item visible just past target) */
        const p=this.progress();
        if(p>.72&&!anticipationFired){anticipationFired=true;pNearMiss();}
      },
      onComplete(){
        /* STEP 2: PRP pause 520ms (Dixon 2019) — perceived reward value increases */
        setTimeout(()=>{
          /* STEP 3: slowly ease BACK to final position — the "oh, it came back" moment */
          gsap.to(tEl,{
            y:finalY,
            duration:.62,
            ease:'power2.inOut', /* smooth settle — not elastic */
            onComplete(){
              /* Lock state with CS2 rarity color */
              rEl.classList.remove('lk-value','lk-high','lk-jackpot');
              rEl.classList.add('lk-'+pick.rar);
              /* Scaled particles by rarity (Cherkasova: reward magnitude encoding) */
              const rb=rEl.getBoundingClientRect();
              const bx=rb.left+rb.width/2,by=rb.top+rb.height/2;
              if(pick.rar==='jackpot'){
                burst(bx,by,'#ffd700',28,1.3);
                burst(bx,by,'#d32ce6',20,1.1);
                burst(bx,by,'#ef3340',16,1.0);
                pJackpot();
              }else if(pick.rar==='high'){
                burst(bx,by,'#d32ce6',24,1.1);
                burst(bx,by,'#9b5de5',16,.9);
                pLock('high');
              }else if(pick.rar==='value'){
                burst(bx,by,'#4b69ff',18);
                pLock('value');
              }else{
                burst(bx,by,'#78909c',12,.8);
                pLock('common');
              }
              /* Flash reveal (FIFA UT pack light effect) */
              gsap.fromTo(rEl,{backgroundColor:'rgba(255,255,255,.18)'},{backgroundColor:'transparent',duration:.42,ease:'power2.out'});
              if(onDone)onDone();
            }
          });
        },520); /* Dixon 2019: PRP = 520ms between reel locks */
      }
    });
  },delay);
}

/* ══════════════════════════════════════════════
   PICK CARD BUILDER
══════════════════════════════════════════════ */
function buildCard(pick){
  const rarCls=pick.rar;
  /* Color selection matches CS2 rarity hierarchy */
  const oddsClr=rarCls==='jackpot'?'gold':rarCls==='high'?'pink':'lime';

  const wrap=document.createElement('div');
  wrap.className='pcard-wrap';wrap.dataset.mkt=pick.mkt.key;

  const card=document.createElement('div');
  card.className=`pcard r-${rarCls}`;

  card.innerHTML=`
    <div class="pc-hero"><img src="${pick.imgUrl}" alt=""><div class="pc-hero-g"></div></div>
    <div class="rar rar-${rarCls}">${RAR_LBL[rarCls]}</div>
    <div class="pc-body">
      <div class="mkt-badge ${pick.mkt.cls}">${pick.mkt.icon} ${pick.mkt.label}</div>
      <div class="pc-matchrow">
        <div class="pc-players">
          <div class="pc-backed">${pick.player}</div>
          <div class="pc-vs">vs</div>
          <div class="pc-opp">${pick.opp}</div>
        </div>
        <div class="pc-oddsblk">
          <div class="pc-oddsval ${oddsClr}">${pick.odds.toFixed(2)}</div>
          <div class="pc-oddslbl">kurs</div>
        </div>
      </div>
      <div class="pc-sel">${pick.selDesc}</div>
      <div class="prob-stack">
        <div class="prob-row">
          <span class="prob-lbl">Model P</span>
          <div class="prob-track"><div class="prob-fill ${rarCls==='jackpot'?'pf-g':rarCls==='high'?'pf-p':'pf-b'}" data-v="${(pick.pM*100).toFixed(0)}"></div></div>
          <span class="prob-val">${(pick.pM*100).toFixed(0)}%</span>
        </div>
        <div class="prob-row">
          <span class="prob-lbl">Bukmacher P</span>
          <div class="prob-track"><div class="prob-fill pf-c" data-v="${(pick.pB*100).toFixed(0)}"></div></div>
          <span class="prob-val">${(pick.pB*100).toFixed(0)}%</span>
        </div>
        <div class="prob-row">
          <span class="prob-lbl">Edge (+wartosc)</span>
          <div class="prob-track"><div class="prob-fill pf-g" data-v="${Math.min(pick.edge,55)/55*100}"></div></div>
          <span class="prob-val" style="color:var(--gold)">+${pick.edge.toFixed(1)}%</span>
        </div>
      </div>
      <div class="pc-reason">
        <div class="pr-hdr">Dlaczego model typuje to?</div>
        <div class="pr-factors">
          ${pick.reasons.map(r=>`
            <div class="prf">
              <div class="prf-dot ${r.pos===true?'pos':r.pos===false?'neg':'neu'}"></div>
              <span>${r.txt}</span>
            </div>`).join('')}
        </div>
      </div>
      <div class="pc-tags">
        <div class="ptag pg">${pick.surf==='grass'?'Trawa':'Clay'}</div>
        <div class="ptag">${pick.tour}</div>
        <div class="ptag">Kelly: ${(Math.max(0,pick.edge/100/(pick.odds-1))*.25*1e3).toFixed(0)} PLN</div>
      </div>
      <div class="pc-conf">
        <span class="conf-lbl">Pewnosc modelu</span>
        <div class="conf-bar"><div class="conf-fill" data-v="${(pick.conf*100).toFixed(0)}"></div></div>
        <span class="conf-val">${(pick.conf*100).toFixed(0)}%</span>
      </div>
    </div>`;

  wrap.appendChild(card);
  return{wrap,card};
}

/* ══════════════════════════════════════════════
   GENERATE FLOW — 5 phases
   Phase timing: anticipation dominates (Jauhar 2021)
══════════════════════════════════════════════ */
let genPicks=[],isGen=false;

document.getElementById('btn-gen').addEventListener('click',()=>{
  if(isGen)return;isGen=true;AC();
  document.getElementById('btn-gen').disabled=true;
  document.getElementById('csummary').style.display='none';
  document.getElementById('cards-area').innerHTML='';
  genPicks=livePicks&&livePicks.length?livePicks:DEMO;

  const ov=document.getElementById('ov');
  ['ovp1','ovp2','ovp3','ovp4'].forEach(id=>document.getElementById(id).classList.remove('on'));
  ['r0','r1','r2'].forEach(id=>document.getElementById(id).classList.remove('lk-value','lk-high','lk-jackpot'));
  gsap.set('#slt',{opacity:0,y:14});
  ov.classList.add('on');gsap.set(ov,{opacity:0});

  const tl=gsap.timeline();

  /* Phase 1: SCAN — builds anticipation */
  tl.to(ov,{opacity:1,duration:.3})
    .call(()=>{document.getElementById('ovp1').classList.add('on');gsap.set(['#ob1','#ob2','#ob3','#ob4'],{width:'0%'});})
    .call(()=>scramble(document.getElementById('ovtxt'),'SKANOWANIE MECZY ATP...',520))
    .to('#ob1',{width:'100%',duration:1.3,ease:'power1.inOut',onUpdate(){if(Math.random()<.1)pTick()}})
    .call(()=>scramble(document.getElementById('ovtxt'),'WINNER / HANDICAP PREDICTION...',440))
    .to('#ob2',{width:'100%',duration:1.05,ease:'power1.inOut',onUpdate(){if(Math.random()<.08)pTick()}})
    .call(()=>scramble(document.getElementById('ovtxt'),'TOTAL SETS / SCORE MARKET...',400))
    .to('#ob3',{width:'100%',duration:.9,ease:'power1.inOut',onUpdate(){if(Math.random()<.07)pTick()}})
    .call(()=>scramble(document.getElementById('ovtxt'),'KELLY SIZING & EDGE RANKING...',360))
    .to('#ob4',{width:'100%',duration:.72,ease:'power1.inOut',onUpdate(){if(Math.random()<.06)pTick()}})
    .to('#ovp1',{opacity:0,y:-18,duration:.3})
    .call(()=>document.getElementById('ovp1').classList.remove('on'))

  /* Phase 2: FOUND */
    .call(()=>{
      document.getElementById('ovp2').classList.add('on');
      document.getElementById('ovsub').textContent=(genPicks[0]?.tour||'ATP 2026')+' · edge >10%';
      gsap.set('#ovp2',{opacity:0,scale:.7});gsap.to('#ovp2',{opacity:1,scale:1,duration:.5,ease:'back.out(1.5)'});
      const cnt=document.getElementById('ovcnt');let c=0;
      const iv=setInterval(()=>{c++;cnt.textContent=c;burst(innerWidth/2,innerHeight*.45,'#c2ff3d',8);pTick();if(c>=genPicks.length)clearInterval(iv);},380);
    })
    .to({},{duration:genPicks.length*.44+.4})
    .to('#ovp2',{opacity:0,scale:1.2,duration:.3})
    .call(()=>document.getElementById('ovp2').classList.remove('on'))

  /* Phase 3: SUSPENSE 3-2-1 — PEAK DOPAMINE (Schultz 2016)
     Ascending tone 200→800Hz during this phase (Cherkasova 2018) */
    .call(()=>{
      document.getElementById('ovp3').classList.add('on');
      gsap.set('#ovp3',{opacity:0});gsap.to('#ovp3',{opacity:1,duration:.28});
      scramble(document.getElementById('ovst'),'PRZYGOTOWANIE KUPONU...',380);
      anticipationTone(2.4); /* 200Hz→800Hz ascending — Cherkasova specification */
      dramaDrone();
      const cd=document.getElementById('ovcd');
      [3,2,1].forEach((n,i)=>{
        setTimeout(()=>{
          cd.textContent=n;pCount();
          gsap.fromTo(cd,{scale:1.7,opacity:0},{scale:1,opacity:1,duration:.3,ease:'back.out(1.5)'});
          if(n===1){
            /* Peak moment — color flash + particles */
            gsap.to(cd,{color:'var(--lime)',duration:.25,delay:.08});
            burst(innerWidth/2,innerHeight*.5,'#c2ff3d',20,1.4);
            burst(innerWidth/2,innerHeight*.5,'#ffd700',12,1.2);
          }
        },i*720);
      });
    })
    .to({},{duration:2.55})
    .to('#ovp3',{opacity:0,duration:.24})
    .call(()=>document.getElementById('ovp3').classList.remove('on'))

  /* Phase 4: SLOT MACHINE — with near-miss overshoot */
    .call(()=>{
      document.getElementById('ovp4').classList.add('on');
      gsap.set('#ovp4',{opacity:0,y:26});gsap.to('#ovp4',{opacity:1,y:0,duration:.42,ease:'back.out(1.5)'});
      for(let i=0;i<3;i++)buildTrack(document.getElementById('rt'+i),genPicks[i]||DEMO[0]);
      pLaunch();
      let done=0;
      /* Staggered reels — each with PRP pause built in */
      for(let i=0;i<3;i++){
        /* Delay between reels = 760ms + PRP padding (Dixon 2019 stagger pattern) */
        spinReel(document.getElementById('rt'+i),document.getElementById('r'+i),genPicks[i]||DEMO[0],i*820,()=>{
          done++;
          if(done===3){
            const tot=genPicks.reduce((a,p)=>a*p.odds,1);
            document.getElementById('stv').textContent=tot.toFixed(2);
            gsap.to('#slt',{opacity:1,y:0,duration:.65,ease:'elastic.out(1.2,.5)',delay:.12});
            gsap.from('#stv',{scale:.28,duration:.65,ease:'elastic.out(1.5,.4)',delay:.12});
            /* Jackpot celebration — rain + burst (Cherkasova: win cues increase risky behavior) */
            rain('#c2ff3d',40);rain('#ffd700',22);rain('#d32ce6',14);
            pJackpot();
            setTimeout(()=>{
              gsap.to(ov,{opacity:0,scale:.95,duration:.42,ease:'power2.in',onComplete:()=>{
                ov.classList.remove('on');gsap.set(ov,{scale:1,opacity:0});
                dealFlipCards(genPicks);
              }});
            },2200);
          }
        });
      }
    });
});

/* ══════════════════════════════════════════════
   FLIP CARD DEAL — FIFA UT pack opening
   Special cards flip 2x slower (FIFA UT "tell")
   Rarity color encoding fires dopamine before name is read
══════════════════════════════════════════════ */
function dealFlipCards(picks){
  const area=document.getElementById('cards-area');

  picks.forEach((pick,i)=>{
    const{wrap,card}=buildCard(pick);

    const flipWrap=document.createElement('div');flipWrap.className='flip-wrap';
    const flipCard=document.createElement('div');flipCard.className='flip-card';
    /* FIFA UT: special cards (jackpot/high) flip slower — visual "tell" */
    const flipDuration=pick.rar==='jackpot'?1.0:pick.rar==='high'?.82:.65;
    gsap.set(flipCard,{height:136,rotateY:0});

    const front=document.createElement('div');front.className='flip-f';
    front.innerHTML=`<div class="ffi"><img src="https://v3b.fal.media/files/b/0a9fe17c/5aXGKPrN0YKu8ZD2fKCcS_UD57jLsn.png" alt=""></div><div class="fft">TYP ${i+1} &mdash; ${pick.mkt.icon} ${pick.mkt.label}</div>`;

    wrap.style.cssText='position:absolute;top:0;left:0;width:100%;backface-visibility:hidden;-webkit-backface-visibility:hidden;border-radius:var(--r)';
    gsap.set(wrap,{rotateY:180});

    const flash=document.createElement('div');flash.className='flip-flash';
    /* Rarity-colored flash — CS2 color fires dopamine instantly (Clark 2009) */
    flash.style.background=RAR_COLOR[pick.rar]||'#fff';
    flash.style.opacity='0';

    flipCard.appendChild(front);flipCard.appendChild(wrap);flipCard.appendChild(flash);
    flipWrap.appendChild(flipCard);area.appendChild(flipWrap);

    gsap.from(flipWrap,{opacity:0,y:44,duration:.38,ease:'back.out(1.5)',delay:i*.09});

    setTimeout(()=>{
      pFlip();
      gsap.to(flipCard,{
        rotateY:180,duration:flipDuration,ease:'power3.inOut',
        onUpdate:function(){
          const p=this.progress();
          gsap.set(flash,{opacity:p>.38&&p<.62?.78:0});
        },
        onComplete(){
          /* Animate bars after reveal */
          card.querySelectorAll('.prob-fill,.conf-fill').forEach(b=>{
            const v=parseFloat(b.dataset.v)||0;
            gsap.to(b,{width:v+'%',duration:.95,ease:'power2.out',delay:.05});
          });
          gsap.set(flipCard,{height:'auto'});

          const rb=flipWrap.getBoundingClientRect();
          const bx=rb.left+rb.width/2,by=rb.top+rb.height/2;
          if(pick.rar==='jackpot'){burst(bx,by,'#ffd700',30,1.3);burst(bx,by,'#d32ce6',22,1.1);burst(bx,by,'#ef3340',16,1.0);pJackpot();}
          else if(pick.rar==='high'){burst(bx,by,'#d32ce6',26,1.1);burst(bx,by,'#9b5de5',18,.9);pLock('high');}
          else if(pick.rar==='value'){burst(bx,by,'#4b69ff',18);pLock('value');}
          else{burst(bx,by,'#78909c',10,.7);}

          if(i===picks.length-1)setTimeout(()=>showCoupon(picks),680);
        }
      });
    },750+i*680);
  });

  isGen=false;
  document.getElementById('btn-gen').disabled=false;
}

function showCoupon(picks){
  const cs=document.getElementById('csummary');cs.style.display='flex';
  const tot=picks.reduce((a,p)=>a*p.odds,1);
  const avgP=picks.reduce((a,p)=>a*p.pM,1);
  const ev=((tot*avgP)-1)*100;
  const avgE=picks.reduce((a,p)=>a+p.edge,0)/picks.length;
  const kelly=Math.min((avgE/100)/(tot-1)*.3*1e3,300);
  document.getElementById('cs-o').textContent=tot.toFixed(2);
  document.getElementById('cs-ev').textContent='+'+ev.toFixed(1)+'%';
  document.getElementById('cs-k').textContent=kelly.toFixed(0)+' PLN';
  gsap.fromTo(cs,{opacity:0,y:18},{opacity:1,y:0,duration:.5,ease:'back.out(1.5)'});
  burst(innerWidth/2,innerHeight-110,'#c2ff3d',28);
  const mkts=new Set(picks.map(p=>p.mkt.key)).size;
  toast(`Kupon gotowy — ${picks.length} typy, ${mkts} rynki`,'lime');
}

document.getElementById('btn-exp').addEventListener('click',()=>{
  if(!genPicks.length)return;
  const tot=genPicks.reduce((a,p)=>a*p.odds,1);
  const txt=genPicks.map(p=>`${p.mkt.icon} [${p.mkt.label.toUpperCase()}]\n  Selekcja: ${p.sel}\n  Kurs: ${p.odds.toFixed(2)} | Edge: +${p.edge.toFixed(1)}% | Model P: ${(p.pM*100).toFixed(0)}%`).join('\n\n');
  navigator.clipboard.writeText(`betatp.io — Daily Kupon\n${new Date().toLocaleDateString('pl-PL')}\n${'─'.repeat(36)}\n\n${txt}\n\n${'─'.repeat(36)}\nLaczny kurs: ${tot.toFixed(2)}\n— LightGBM v14 (AUC 0.9031) | betatp.io`).then(()=>{toast('Kupon skopiowany!','lime');gsap.to('#btn-exp',{scale:.95,yoyo:true,repeat:1,duration:.08});});
});

/* ══════════════════════════════════════════════
   SYSTEM BUILDER — 3 markets per match
══════════════════════════════════════════════ */
let sysPicks=[];
function renderMatches(){
  const list=document.getElementById('mlist');list.innerHTML='';
  MATCHES.forEach((m,mi)=>{
    const hasSel=sysPicks.find(p=>p.mid===m.id);
    const div=document.createElement('div');div.className='mrow'+(hasSel?' sel':'');
    div.innerHTML=`
      <div class="mr-top"><span>${m.p1}</span><span class="mr-vs">vs</span><span>${m.p2}</span><span class="mr-time">${m.t}</span></div>
      <div class="mr-mkts">
        <div class="mr-mkt-row"><div class="mr-mkt-lbl">🏆 Winner</div><div class="mr-btns">
          ${m.w.map(o=>`<div class="mrb mw${sysPicks.find(p=>p.mid===m.id&&p.s===o.s)?' a':''}" data-mid="${m.id}" data-s="${o.s}" data-o="${o.o}" data-e="${o.e}" data-mkt="winner">
            <span class="mrb-n">${o.s.split(' ').slice(0,2).join(' ')}</span>
            <span class="mrb-o">${o.o.toFixed(2)}</span>
            <span class="mrb-e ${o.e>=10?'eg':o.e>=5?'eo':'en'}">${o.e>0?'+':''}${o.e.toFixed(1)}%</span></div>`).join('')}
        </div></div>
        <div class="mr-mkt-row"><div class="mr-mkt-lbl">± Handicap</div><div class="mr-btns">
          ${m.h.map(o=>`<div class="mrb mh${sysPicks.find(p=>p.mid===m.id&&p.s===o.s)?' a':''}" data-mid="${m.id}" data-s="${o.s}" data-o="${o.o}" data-e="${o.e}" data-mkt="handicap">
            <span class="mrb-n">${o.s}</span>
            <span class="mrb-o">${o.o.toFixed(2)}</span>
            <span class="mrb-e ${o.e>=10?'eg':o.e>=5?'eo':'en'}">${o.e>0?'+':''}${o.e.toFixed(1)}%</span></div>`).join('')}
        </div></div>
        <div class="mr-mkt-row"><div class="mr-mkt-lbl">∑ Total Sets</div><div class="mr-btns">
          ${m.to.map(o=>`<div class="mrb mt${sysPicks.find(p=>p.mid===m.id&&p.s===o.s)?' a':''}" data-mid="${m.id}" data-s="${o.s}" data-o="${o.o}" data-e="${o.e}" data-mkt="total">
            <span class="mrb-n">${o.s}</span>
            <span class="mrb-o">${o.o.toFixed(2)}</span>
            <span class="mrb-e ${o.e>=10?'eg':o.e>=5?'eo':'en'}">${o.e>0?'+':''}${o.e.toFixed(1)}%</span></div>`).join('')}
        </div></div>
      </div>`;
    div.querySelectorAll('.mrb').forEach(btn=>btn.addEventListener('click',e=>{
      e.stopPropagation();AC();pTick();
      const mid=parseInt(btn.dataset.mid),s=btn.dataset.s,o=parseFloat(btn.dataset.o),edge=parseFloat(btn.dataset.e),mkt=btn.dataset.mkt;
      const idx=sysPicks.findIndex(p=>p.mid===mid);
      if(idx!==-1){if(sysPicks[idx].s===s)sysPicks.splice(idx,1);else sysPicks[idx]={mid,s,o,edge,mkt};}
      else{if(sysPicks.length>=8){toast('Max 8 typow');return;}sysPicks.push({mid,s,o,edge,mkt});}
      renderMatches();renderTray();updateFoot();
      gsap.fromTo(btn,{scale:1.14},{scale:1,duration:.25,ease:'elastic.out(1.5,.4)'});
    }));
    list.appendChild(div);
    gsap.from(div,{opacity:0,x:-7,duration:.18,ease:'power2.out',delay:mi*.022});
  });
}
function renderTray(){
  const tray=document.getElementById('stray'),empty=document.getElementById('te');
  tray.querySelectorAll('.titem').forEach(el=>el.remove());
  empty.style.display=sysPicks.length?'none':'flex';
  sysPicks.forEach((p,i)=>{
    const item=document.createElement('div');item.className='titem';
    item.innerHTML=`<span class="ti-n">${p.s.split(' ').slice(0,2).join(' ')}</span><span class="ti-m">${MKT_ICONS[p.mkt]||''}</span><span class="ti-o">${p.o.toFixed(2)}</span><div class="ti-rm" data-i="${i}">✕</div>`;
    item.querySelector('.ti-rm').addEventListener('click',()=>{sysPicks.splice(i,1);renderMatches();renderTray();updateFoot();});
    tray.insertBefore(item,empty);
    gsap.from(item,{opacity:0,x:12,duration:.22,ease:'back.out(1.5)',delay:i*.04});
  });
}
function updateFoot(){
  const n=sysPicks.length;
  document.getElementById('sf-cnt').textContent=n+'/8';
  if(!n){document.getElementById('sf-o').textContent='1.00';document.getElementById('sf-e').textContent='--';document.getElementById('btn-sys').classList.remove('rdy');return;}
  const tot=sysPicks.reduce((a,p)=>a*p.o,1);
  const avg=sysPicks.reduce((a,p)=>a+p.edge,0)/n;
  const el=document.getElementById('sf-o');
  const obj={v:parseFloat(el.textContent)||1};
  gsap.to(obj,{v:tot,duration:.4,ease:'power2.out',onUpdate:()=>{el.textContent=obj.v.toFixed(2);}});
  document.getElementById('sf-e').textContent=(avg>0?'+':'')+avg.toFixed(1)+'%';
  document.getElementById('btn-sys').classList[n>=2?'add':'remove']('rdy');
}
document.getElementById('btn-sys').addEventListener('click',()=>{
  if(sysPicks.length<2)return;
  const tot=sysPicks.reduce((a,p)=>a*p.o,1);
  const avg=sysPicks.reduce((a,p)=>a+p.edge,0)/sysPicks.length;
  const kelly=Math.min((avg/100)/(tot-1)*.3*1e3,400);
  pJackpot();rain('#00f2e8',32);rain('#ffd700',18);
  gsap.fromTo('#sf-o',{color:'#fff',scale:1.38},{color:'var(--cyan)',scale:1,duration:.55,ease:'elastic.out(1.2,.5)'});
  gsap.to('#btn-sys',{scale:.93,yoyo:true,repeat:1,duration:.1});
  toast(`${sysPicks.length} typow | Kurs: ${tot.toFixed(2)} | Kelly: ${kelly.toFixed(0)} PLN`,'gold');
});

/* ══════════════════════════════════════════════
   TOAST
══════════════════════════════════════════════ */
function toast(msg,type,d=3200){
  const t=document.createElement('div');
  t.className='tm'+(type?' '+type:'');
  t.textContent=msg;
  document.getElementById('ta').appendChild(t);
  setTimeout(()=>gsap.to(t,{opacity:0,y:8,duration:.28,onComplete:()=>t.remove()}),d);
}

/* ══════════════════════════════════════════════
   ENTRANCE — staggered buildup (anticipation primer)
   Primes dopamine system before any interaction
   Each element enters with increasing delay → builds expectation
══════════════════════════════════════════════ */
const enter=gsap.timeline({delay:.28});
enter
  .from('.logo-pill',{y:-22,opacity:0,duration:.7,ease:'power2.out'})
  .from('#ht',{y:65,opacity:0,duration:1.0,ease:'power3.out'},'.18')
  .from('#s-home .hero-sub',{y:20,opacity:0,duration:.65,ease:'power2.out'},'.38')
  .from('.market-row',{y:16,opacity:0,duration:.5,ease:'power2.out'},'.52')
  .from('.hcard',{y:68,opacity:0,duration:.95,ease:'back.out(1.5)',stagger:.18},'.65')
  .from('.sp-ticker',{y:22,opacity:0,duration:.45,ease:'power2.out'},'.9');

/* Persistent logo glow pulse */
enter.call(()=>{
  gsap.to('.logo-pill',{boxShadow:'0 0 0 3px rgba(194,255,61,.11)',yoyo:true,repeat:-1,duration:2.8,ease:'sine.inOut'});
});
</script>
</body>
</html>
