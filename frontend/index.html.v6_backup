<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
<title>betatp.io — AI Value Betting ATP</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════════════════════
   DESIGN SYSTEM v6.0 — RESEARCH-BACKED DOPAMINE UX
   Sources: Schultz 2016 (RPE), Berridge 2016 (wanting vs liking),
            Clark 2009 (near-miss Neuron), Cherkasova 2018 (JNeurosci),
            Dixon 2019 (PRP), Barton 2017 (51-study review),
            DraftKings #61B510, FanDuel navy, CS2 rarity colors
═══════════════════════════════════════════════════════════════════ */
:root{
  /* SURFACES — DraftKings dark depth system */
  --bg:#020208; --s0:#05050f; --s1:#08081a; --s2:#0d0d24;
  --s3:#14142e; --s4:#1c1c38; --s5:#242444;
  /* BORDERS */
  --bd0:rgba(255,255,255,.035); --bd1:rgba(255,255,255,.07);
  --bd2:rgba(255,255,255,.13); --bd3:rgba(255,255,255,.22);
  /* TEXT */
  --t1:#eeeeff; --t2:rgba(238,238,255,.5);
  --t3:rgba(238,238,255,.22); --t4:rgba(238,238,255,.09);
  /* PRIMARY BRAND — DraftKings Vida Loca #61B510, FanDuel neon + own identity */
  --lime:#c2ff3d; --lime2:#7cb800;   /* FanDuel-inspired sharp lime */
  --dk-green:#61b510;                /* DraftKings exact (Vida Loca) */
  --gold:#ffd700; --gold2:#c47a00;
  --cyan:#00f2e8; --cyan2:#00aaa2;
  --violet:#9b5de5; --violet2:#5421a8;
  --red:#ef3340; --red2:#8b0000;
  --pink:#d32ce6; --pink2:#7b0086;   /* CS2 Classified tier */
  --blue:#4b69ff; --blue2:#1a3299;   /* CS2 Mil-Spec tier */
  --orange:#f76d00;
  /* ══════════════════════════════════════════
     CS2 RARITY COLOR SYSTEM (Barton 2017 + Clark 2009)
     Each tier uses progressively more arousing color
     Grey→Blue→Purple→Pink→Red→Gold = engineered dopamine ramp
     Color itself fires dopamine BEFORE user reads item name
  ══════════════════════════════════════════ */
  --rar-common:  rgba(120,144,156,.7);   /* blue-grey — low arousal */
  --rar-value:   var(--blue);            /* blue — trust + mild desire */
  --rar-high:    var(--pink);            /* pink/magenta — high arousal, desire */
  --rar-jackpot: var(--gold);            /* gold — treasure, peak value signal */
  /* TYPOGRAPHY */
  --f:'Cabinet Grotesk',sans-serif;
  --m:'JetBrains Mono',monospace;
  /* TIMING — Schultz 2016 + NN/g 2020 + Stanford GSB 2025 */
  --t-snap:60ms;   /* immediate physical feedback */
  --t-fast:160ms;  /* standard UI acknowledgment */
  --t-mid:300ms;   /* modal entrance */
  --t-slow:500ms;  /* large transition */
  /* Reward-specific — anticipation PEAKS at 2-8s (Jauhar 2021) */
  --t-build:2200ms; --t-drama:4000ms;
  /* Moderate speed = min perceived wait (Ding & Kyung, Stanford 2025) */
  --t-reveal:280ms;    /* not too fast, not too slow */
  --t-celebrate:1600ms;
  --t-prp:520ms;  /* Post-Reinforcement Pause, Dixon 2019 */
  /* EASING */
  --ease-out:cubic-bezier(.16,1,.3,1);
  --ease-back:cubic-bezier(.34,1.56,.64,1);
  --ease-spring:cubic-bezier(.68,-.55,.27,1.55);
  --ease-reel:cubic-bezier(.06,.96,.22,1); /* decel for slot */
  --r:14px; --r-s:8px; --r-l:20px; --r-full:9999px;
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;min-height:100dvh;background:var(--bg);color:var(--t1);font-family:var(--f);overflow-x:hidden;-webkit-font-smoothing:antialiased}
img{display:block}
button{cursor:pointer;font-family:var(--f)}
#bg{position:fixed;inset:0;z-index:0;pointer-events:none}
#pc{position:fixed;inset:0;z-index:99;pointer-events:none}
.screen{position:fixed;inset:0;z-index:10;display:flex;flex-direction:column;overflow:hidden}
.screen.off{display:none}

/* ═══ SCANLINE TEXTURE — authentic CRT/casino feel ═══ */
body::after{content:'';position:fixed;inset:0;z-index:1;pointer-events:none;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.025) 2px,rgba(0,0,0,.025) 4px);opacity:.6}

/* ═══════════════════════════════════
   HOME SCREEN
═══════════════════════════════════ */
#s-home{align-items:center;justify-content:center}
.hero-bg{
  position:absolute;inset:0;z-index:0;
  background-image:url('https://v3b.fal.media/files/b/0a9fe194/OmleGlGP6yI7XnDM8_Dso_LS3kyGPL.png');
  background-size:cover;background-position:center;
}
.hero-bg::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 90% 70% at 50% 50%,rgba(2,2,8,.42) 0%,rgba(2,2,8,.78) 55%,rgba(2,2,8,.98) 100%)}

/* Logo pill */
.logo-pill{
  position:absolute;top:18px;left:50%;transform:translateX(-50%);z-index:5;
  display:flex;align-items:center;gap:8px;padding:5px 14px;
  border-radius:var(--r-full);border:1px solid var(--bd2);
  background:rgba(2,2,8,.9);backdrop-filter:blur(18px);
  font-size:9px;font-weight:800;letter-spacing:.16em;color:var(--t3);text-transform:uppercase;
}
.ldot{width:5px;height:5px;border-radius:50%;background:var(--lime);animation:ldot 1.8s ease infinite}
@keyframes ldot{0%,100%{opacity:1}50%{opacity:.14}}
.lpill-badge{padding:1px 6px;border-radius:var(--r-full);background:rgba(193,255,62,.1);border:1px solid rgba(193,255,62,.18);color:var(--lime);font-size:7px;font-weight:800;letter-spacing:.1em}

/* Social proof ticker — shows backtest ROI (Cialdini 1984 social proof principle) */
.sp-ticker{
  position:absolute;bottom:0;left:0;right:0;z-index:5;
  padding:5px 0;border-top:1px solid var(--bd1);
  background:rgba(2,2,8,.85);backdrop-filter:blur(12px);
  overflow:hidden;
}
.sp-inner{display:flex;gap:0;animation:ticker 24s linear infinite;white-space:nowrap;width:max-content}
.sp-item{display:inline-flex;align-items:center;gap:5px;padding:0 20px;font-size:8px;font-family:var(--m);color:var(--t3);white-space:nowrap}
.sp-item .sp-v{color:var(--lime);font-weight:700}
.sp-item .sp-g{color:var(--gold);font-weight:700}
.sp-sep{color:var(--bd2);padding:0 8px}
@keyframes ticker{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* Hero text */
.hero-center{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:10px;margin-bottom:30px;text-align:center}
.hero-t{
  font-size:clamp(90px,15.5vw,225px);font-weight:900;
  letter-spacing:-.065em;line-height:.83;
  background:linear-gradient(128deg,var(--t1) 0%,var(--lime) 42%,var(--cyan) 80%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  filter:drop-shadow(0 0 80px rgba(194,255,61,.16));
}
.hero-sub{font-size:10px;color:var(--t3);font-weight:700;letter-spacing:.14em;text-transform:uppercase;font-family:var(--m)}

/* Market chips */
.market-row{display:flex;gap:5px;flex-wrap:wrap;justify-content:center;position:relative;z-index:2;margin-top:5px}
.mc{padding:3px 9px;border-radius:var(--r-full);font-size:8px;font-weight:800;letter-spacing:.06em;text-transform:uppercase;border:1px solid var(--bd1);background:rgba(255,255,255,.03);color:var(--t3)}
.mc.l{border-color:rgba(194,255,61,.26);color:var(--lime);background:rgba(194,255,61,.06)}
.mc.c{border-color:rgba(0,242,232,.2);color:var(--cyan);background:rgba(0,242,232,.05)}
.mc.g{border-color:rgba(255,215,0,.2);color:var(--gold);background:rgba(255,215,0,.05)}
.mc.v{border-color:rgba(155,93,229,.2);color:var(--violet);background:rgba(155,93,229,.05)}
.mc.b{border-color:rgba(75,105,255,.2);color:var(--blue);background:rgba(75,105,255,.05)}

/* Deck cards */
.deck{display:flex;gap:14px;padding:0 16px;perspective:1400px;position:relative;z-index:2}
@media(max-width:540px){.deck{flex-direction:column;align-items:center}}
.hcard{position:relative;width:240px;height:276px;border-radius:var(--r-l);cursor:pointer;transform-style:preserve-3d;will-change:transform}
.hcard-in{position:absolute;inset:0;border-radius:var(--r-l);overflow:hidden;background:var(--s1);border:1px solid var(--bd1);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:11px;padding:20px 16px;backface-visibility:hidden}
.hfoil{position:absolute;inset:-1px;border-radius:var(--r-l);pointer-events:none;background:conic-gradient(from 0deg at 50% 50%,rgba(194,255,61,.14),rgba(0,242,232,.11),rgba(155,93,229,.09),rgba(255,215,0,.09),rgba(194,255,61,.14));opacity:0;mix-blend-mode:screen;transition:opacity .3s;animation:foilS 4s linear infinite paused}
@keyframes foilS{to{transform:rotate(360deg) scale(1.5)}}
.hcard:hover .hfoil{opacity:1;animation-play-state:running}
.hglare{position:absolute;inset:0;border-radius:var(--r-l);pointer-events:none;background:radial-gradient(circle at var(--mx,50%) var(--my,50%),rgba(255,255,255,.16),transparent 56%);opacity:0;transition:opacity .25s}
.hcard:hover .hglare{opacity:1}
.hbrd{position:absolute;inset:-1px;border-radius:21px;pointer-events:none;box-shadow:0 0 0 0 transparent;transition:box-shadow .3s}
.hcard-d:hover .hbrd{box-shadow:0 0 0 1px rgba(194,255,61,.48),0 0 30px rgba(194,255,61,.13)}
.hcard-s:hover .hbrd{box-shadow:0 0 0 1px rgba(0,242,232,.48),0 0 30px rgba(0,242,232,.11)}
.hcico{width:52px;height:52px;border-radius:12px;overflow:hidden;display:flex;align-items:center;justify-content:center}
.hcard-d .hcico{background:rgba(194,255,61,.09)}
.hcard-s .hcico{background:rgba(0,242,232,.08)}
.hcico img{width:34px;height:34px;object-fit:contain}
.hctitle{font-size:16px;font-weight:900;letter-spacing:-.02em;text-align:center}
.hcdesc{font-size:10px;color:var(--t2);text-align:center;line-height:1.5}
.hctag{padding:3px 10px;border-radius:var(--r-full);font-size:7px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;margin-top:2px}
.hcard-d .hctag{background:rgba(194,255,61,.11);color:var(--lime);border:1px solid rgba(194,255,61,.2)}
.hcard-s .hctag{background:rgba(0,242,232,.09);color:var(--cyan);border:1px solid rgba(0,242,232,.18)}

/* ═══ NAV ═══ */
.nav{display:flex;align-items:center;padding:10px 14px;gap:9px;border-bottom:1px solid var(--bd1);background:rgba(2,2,8,.93);backdrop-filter:blur(28px);flex-shrink:0;position:relative;z-index:20}
.nbk{width:28px;height:28px;border-radius:var(--r-s);background:var(--s2);border:1px solid var(--bd1);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:12px;flex-shrink:0;transition:background var(--t-fast)}
.nbk:hover{background:var(--s3)}
.ntitle{font-size:13px;font-weight:900;flex:1;letter-spacing:-.01em}
.nbadge{font-size:7px;font-family:var(--m);color:var(--t3);padding:2px 7px;border-radius:5px;background:var(--s2);border:1px solid var(--bd1)}
.nlive{width:5px;height:5px;border-radius:50%;background:var(--lime);animation:ldot 1.8s ease infinite;flex-shrink:0}

/* ═══ MARKET TABS ═══ */
.mktabs{display:flex;gap:0;padding:0 14px;border-bottom:1px solid var(--bd1);background:var(--s0);overflow-x:auto;flex-shrink:0}
.mktabs::-webkit-scrollbar{height:0}
.mktab{padding:9px 14px;font-size:9px;font-weight:800;letter-spacing:.07em;text-transform:uppercase;color:var(--t3);cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:color var(--t-fast),border-color var(--t-fast);flex-shrink:0}
.mktab:hover{color:var(--t2)}
.mktab.on{color:var(--t1);border-bottom-color:var(--lime)}
.mktab.on.sets{border-bottom-color:var(--cyan);color:var(--cyan)}
.mktab.on.handi{border-bottom-color:var(--gold);color:var(--gold)}
.mktab.on.total{border-bottom-color:var(--violet);color:var(--violet)}
.mktab.on.score{border-bottom-color:var(--blue);color:var(--blue)}

/* ═══ API BAR ═══ */
#api-bar{display:flex;align-items:center;gap:6px;padding:5px 14px;background:var(--s0);border-bottom:1px solid var(--bd1);flex-shrink:0}
.ablbl{font-size:7px;font-weight:800;color:var(--t3);letter-spacing:.1em;text-transform:uppercase;white-space:nowrap;font-family:var(--m)}
#api-in{flex:1;height:22px;padding:0 7px;border-radius:5px;background:var(--s2);border:1px solid var(--bd1);color:var(--t1);font-family:var(--m);font-size:9px;outline:none;min-width:0}
#api-in::placeholder{color:var(--t3)}#api-in:focus{border-color:rgba(194,255,61,.28)}
#api-btn{height:22px;padding:0 10px;border-radius:5px;border:1px solid rgba(194,255,61,.18);background:rgba(194,255,61,.06);color:var(--lime);font-size:8px;font-weight:800;transition:background var(--t-fast)}
#api-btn:hover{background:rgba(194,255,61,.13)}
#api-st{font-size:7px;font-weight:800;font-family:var(--m);white-space:nowrap}
#api-st.ok{color:var(--lime)}#api-st.err{color:var(--red)}

/* ═══ DAILY SCREEN ═══ */
#s-daily{background:var(--bg)}
.dbody{flex:1;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:10px;scroll-behavior:smooth}
.dbody::-webkit-scrollbar{display:none}
.dinfo{display:flex;gap:5px;flex-wrap:wrap}
.chip{padding:3px 8px;border-radius:var(--r-full);font-size:8px;font-weight:700;background:var(--s2);border:1px solid var(--bd1);color:var(--t2)}
.chip.lime{background:rgba(194,255,61,.09);color:var(--lime);border-color:rgba(194,255,61,.18)}
.chip.green{background:rgba(0,160,60,.09);color:#00cc55;border-color:rgba(0,160,60,.18)}

/* ═══════════════════════════════════════════════════════════
   PICK CARD — Full transparency + storytelling
   "Kto wie skąd pochodzi predykcja, ten ufa predykcji"
   ITER: market badge, match, selection, prob bars, reasoning
═══════════════════════════════════════════════════════════ */
#cards-area{display:flex;flex-direction:column;gap:12px}

.pcard{border-radius:var(--r);border:1px solid var(--bd1);background:var(--s1);overflow:hidden;position:relative;transition:border-color var(--t-mid)}
/* CS2-inspired rarity pulse animations */
.pcard.r-value{border-color:rgba(75,105,255,.3);background:linear-gradient(135deg,rgba(75,105,255,.04),var(--s1) 55%)}
.pcard.r-high{border-color:rgba(211,44,230,.4);animation:highP 3s ease infinite}
.pcard.r-jackpot{animation:jpP 2.2s ease infinite,jpBdr 2s linear infinite}
@keyframes highP{0%,100%{box-shadow:0 0 0 0 rgba(211,44,230,0)}55%{box-shadow:0 0 34px rgba(211,44,230,.16)}}
@keyframes jpP{0%,100%{box-shadow:0 0 0 0 rgba(255,215,0,0)}55%{box-shadow:0 0 38px rgba(255,215,0,.18)}}
@keyframes jpBdr{0%{border-color:rgba(255,215,0,.4)}33%{border-color:rgba(239,51,64,.4)}66%{border-color:rgba(211,44,230,.4)}100%{border-color:rgba(255,215,0,.4)}}
/* Hover subtle glow */
.pcard::before{content:'';position:absolute;inset:0;opacity:0;transition:opacity var(--t-mid);border-radius:var(--r);background:radial-gradient(ellipse at 50% 0%,rgba(194,255,61,.04),transparent 62%)}
.pcard:hover::before{opacity:1}

.pc-hero{width:100%;height:68px;overflow:hidden;position:relative;background:linear-gradient(135deg,var(--s2),var(--s3))}
.pc-hero img{width:100%;height:100%;object-fit:cover;object-position:center 25%;opacity:.28}
.pc-hero-g{position:absolute;inset:0;background:linear-gradient(to bottom,transparent 22%,var(--s1) 100%)}

/* CS2 authentic rarity badge — color IS the message (Clark 2009) */
.rar{position:absolute;top:9px;right:10px;padding:2px 8px;border-radius:var(--r-full);font-size:7px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;z-index:5}
.rar-common{background:rgba(120,144,156,.18);color:#78909c}
.rar-value{background:rgba(75,105,255,.18);color:var(--blue);border:1px solid rgba(75,105,255,.3)}
/* Pink/magenta = high arousal, desire encoding (neuroaesthetic color theory 2025) */
.rar-high{background:rgba(211,44,230,.2);color:var(--pink);border:1px solid rgba(211,44,230,.4);box-shadow:0 0 12px rgba(211,44,230,.2)}
/* Gold = universal treasure signal (cross-cultural) */
.rar-jackpot{background:linear-gradient(90deg,rgba(239,51,64,.2),rgba(255,215,0,.25));color:var(--gold);border:1px solid rgba(255,215,0,.4);animation:jptxt 1.6s linear infinite;box-shadow:0 0 16px rgba(255,215,0,.2)}
@keyframes jptxt{to{filter:hue-rotate(360deg)}}

.pc-body{padding:12px 14px;display:flex;flex-direction:column;gap:9px}

/* Market badge */
.mkt-badge{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:var(--r-full);font-size:8px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;width:fit-content}
.mb-winner{background:rgba(194,255,61,.09);color:var(--lime);border:1px solid rgba(194,255,61,.2)}
.mb-sets{background:rgba(0,242,232,.08);color:var(--cyan);border:1px solid rgba(0,242,232,.18)}
.mb-handicap{background:rgba(255,215,0,.08);color:var(--gold);border:1px solid rgba(255,215,0,.18)}
.mb-total{background:rgba(155,93,229,.08);color:var(--violet);border:1px solid rgba(155,93,229,.18)}
.mb-score{background:rgba(75,105,255,.08);color:var(--blue);border:1px solid rgba(75,105,255,.18)}

/* Players + odds */
.pc-matchrow{display:flex;align-items:center;justify-content:space-between;gap:10px}
.pc-players{flex:1}
.pc-backed{font-size:15px;font-weight:900;letter-spacing:-.02em;line-height:1.1}
.pc-vs{font-size:8px;color:var(--t3);text-transform:uppercase;letter-spacing:.07em;margin:2px 0 1px}
.pc-opp{font-size:11px;font-weight:600;color:var(--t2)}
.pc-oddsblk{text-align:right;flex-shrink:0}
.pc-oddsval{font-family:var(--m);font-size:26px;font-weight:900;line-height:1;letter-spacing:-.03em}
.pc-oddsval.lime{color:var(--lime);text-shadow:0 0 22px rgba(194,255,61,.28)}
.pc-oddsval.gold{color:var(--gold);text-shadow:0 0 22px rgba(255,215,0,.28)}
.pc-oddsval.pink{color:var(--pink);text-shadow:0 0 22px rgba(211,44,230,.22)}
.pc-oddslbl{font-size:7px;color:var(--t3);text-transform:uppercase;letter-spacing:.08em}

/* Selection — storytelling box */
.pc-sel{padding:8px 10px;border-radius:var(--r-s);background:rgba(255,255,255,.024);border:1px solid var(--bd1);font-size:10px;color:var(--t1);line-height:1.5}
.pc-sel strong{color:var(--lime)}.pc-sel .g{color:var(--gold)}.pc-sel .v{color:var(--violet)}.pc-sel .p{color:var(--pink)}.pc-sel .c{color:var(--cyan)}

/* Probability bars — dual-model vs bookmaker comparison */
.prob-stack{display:flex;flex-direction:column;gap:5px}
.prob-row{display:flex;align-items:center;gap:6px}
.prob-lbl{font-size:8px;font-family:var(--m);font-weight:700;color:var(--t3);width:74px;flex-shrink:0}
.prob-track{flex:1;height:3px;background:rgba(255,255,255,.055);border-radius:2px;overflow:hidden}
.prob-fill{height:100%;border-radius:2px;width:0%}
.pf-l{background:linear-gradient(90deg,var(--lime2),var(--lime))}
.pf-g{background:linear-gradient(90deg,var(--gold2),var(--gold))}
.pf-c{background:linear-gradient(90deg,var(--cyan2),var(--cyan))}
.pf-p{background:linear-gradient(90deg,var(--pink2),var(--pink))}
.pf-b{background:linear-gradient(90deg,var(--blue2),var(--blue))}
.prob-val{font-size:8px;font-family:var(--m);color:var(--t2);width:28px;text-align:right;flex-shrink:0}

/* Model reasoning — PRZEJRZYSTOŚĆ = ZAUFANIE */
.pc-reason{padding:9px 10px;border-radius:var(--r-s);background:rgba(255,255,255,.022);border:1px solid var(--bd1);display:flex;flex-direction:column;gap:5px}
.pr-hdr{font-size:7px;font-weight:800;color:var(--t3);text-transform:uppercase;letter-spacing:.12em;margin-bottom:1px}
.prf{display:flex;align-items:flex-start;gap:6px;font-size:9px;color:var(--t2);line-height:1.4}
.prf-dot{width:4px;height:4px;border-radius:50%;margin-top:4px;flex-shrink:0}
.prf-dot.pos{background:var(--lime)}.prf-dot.neg{background:var(--red)}.prf-dot.neu{background:var(--t3)}

/* Confidence + tags */
.pc-conf{display:flex;align-items:center;gap:8px}
.conf-lbl{font-size:8px;color:var(--t3);font-weight:700;white-space:nowrap;font-family:var(--m)}
.conf-bar{flex:1;height:4px;background:rgba(255,255,255,.045);border-radius:2px;overflow:hidden}
.conf-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--cyan2),var(--lime));width:0%}
.conf-val{font-size:8px;font-family:var(--m);font-weight:700;color:var(--lime);white-space:nowrap}
.pc-tags{display:flex;gap:5px;flex-wrap:wrap}
.ptag{padding:2px 7px;border-radius:var(--r-full);font-size:8px;font-weight:700;border:1px solid var(--bd1);background:var(--s2);color:var(--t2)}
.ptag.pg{background:rgba(0,160,60,.08);color:#00cc55;border-color:rgba(0,160,60,.18)}

/* ═══ COUPON SUMMARY ═══ */
#csummary{border-radius:var(--r);border:1px solid rgba(194,255,61,.2);background:rgba(194,255,61,.036);padding:13px 14px;display:none;flex-direction:column;gap:8px}
.coup-img{width:100%;height:70px;border-radius:var(--r-s);overflow:hidden;border:1px solid var(--bd1);margin-bottom:2px}
.coup-img img{width:100%;height:100%;object-fit:cover;opacity:.45}
.csr{display:flex;align-items:center;justify-content:space-between}
.csl{font-size:9px;color:var(--t3);font-weight:700;text-transform:uppercase;letter-spacing:.06em}
.csv{font-family:var(--m);font-size:12px;font-weight:700;color:var(--lime)}
.cs-big{font-family:var(--m);font-size:32px;font-weight:900;color:var(--lime);letter-spacing:-.04em;line-height:1;text-shadow:0 0 28px rgba(194,255,61,.3)}
#btn-exp{width:100%;height:38px;border-radius:9px;border:1px solid rgba(194,255,61,.18);background:rgba(194,255,61,.065);color:var(--lime);font-size:10px;font-weight:800;letter-spacing:.05em;text-transform:uppercase;transition:background var(--t-fast)}
#btn-exp:hover{background:rgba(194,255,61,.13)}

/* ═══ GEN BUTTON — DraftKings #61B510 CTA with dopamine pulse ═══ */
.dfoot{padding:8px 12px 14px;flex-shrink:0}
#btn-gen{
  width:100%;height:54px;border-radius:12px;border:none;
  font-size:14px;font-weight:900;letter-spacing:.08em;text-transform:uppercase;
  /* DraftKings Vida Loca green as base, lime text for contrast */
  background:linear-gradient(135deg,#4a9d08,var(--dk-green));
  color:#000;position:relative;overflow:hidden;
  /* Dopamine anticipation pulse — variable reward signal (Schultz 2016) */
  animation:btnP 2.8s ease infinite;transition:transform var(--t-snap);
}
@keyframes btnP{0%,100%{box-shadow:0 0 0 0 rgba(97,181,16,.6)}55%{box-shadow:0 0 0 22px rgba(97,181,16,0)}}
#btn-gen:active{transform:scale(.97)}
#btn-gen::after{content:'';position:absolute;inset:0;background:linear-gradient(105deg,transparent 30%,rgba(255,255,255,.22) 50%,transparent 70%);background-size:200% 100%;animation:btnSh 3s ease infinite}
@keyframes btnSh{0%,58%{background-position:200% 0}100%{background-position:-200% 0}}
#btn-gen:disabled{opacity:.32;animation:none;pointer-events:none}

/* ═══════════════════════════════════════════════════════════
   5-PHASE OVERLAY — Neuroscience-aligned ceremony
   Phase timing based on Jauhar 2021 (fMRI meta-analysis):
   Anticipation > Delivery for dopamine activation
   Design: maximize suspense window, not instant reveal
═══════════════════════════════════════════════════════════ */
#ov{position:fixed;inset:0;z-index:100;background:rgba(2,2,8,.98);display:flex;flex-direction:column;align-items:center;justify-content:center;overflow:hidden;opacity:0;pointer-events:none}
#ov.on{opacity:1;pointer-events:all}
.ov-bg{position:absolute;inset:0;background-image:url('https://v3b.fal.media/files/b/0a9fe185/g84L_hEAvlP19geMTTYGr_jaVBZ7KR.png');background-size:cover;background-position:center;opacity:.06;pointer-events:none}
.ov-scanlines{position:absolute;inset:0;pointer-events:none;z-index:1;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.055) 2px,rgba(0,0,0,.055) 4px);opacity:.45}
.ovp{display:none;flex-direction:column;align-items:center;gap:13px;width:100%;max-width:460px;padding:0 22px;position:relative;z-index:2}
.ovp.on{display:flex}
.ovtag{font-size:7px;font-weight:800;letter-spacing:.18em;text-transform:uppercase;color:var(--t3);font-family:var(--m)}
#ovtxt{font-size:13px;font-weight:800;color:var(--t1);min-height:20px;text-align:center;letter-spacing:-.01em}
.ovbars{width:100%;display:flex;flex-direction:column;gap:6px}
.ovbr{display:flex;flex-direction:column;gap:3px}
.ovbl{font-size:7px;font-weight:700;color:var(--t3);letter-spacing:.1em;text-transform:uppercase;font-family:var(--m)}
.ovbt{height:2px;background:rgba(255,255,255,.045);border-radius:1px;overflow:hidden}
.ovbf{height:100%;width:0%;border-radius:1px}
#ob1{background:var(--lime)}#ob2{background:var(--cyan)}
#ob3{background:var(--gold)}#ob4{background:var(--violet)}
/* Phase 2: Found */
.ovcnt{font-family:var(--m);font-size:74px;font-weight:900;color:var(--lime);line-height:1;letter-spacing:-.06em;text-shadow:0 0 65px rgba(194,255,61,.42)}
.ovsub{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--t2)}
/* Phase 3: Suspense — dopamine PEAKS here (Schultz 2016) */
.ovcd{font-family:var(--m);font-size:90px;font-weight:900;color:var(--t1);line-height:1;text-shadow:0 0 80px rgba(255,255,255,.2)}
.ovst{font-size:12px;font-weight:700;color:var(--t2);letter-spacing:.04em;text-align:center}

/* ═══════════════════════════════════════════════════════════
   CS2 SLOT MACHINE — Research-backed near-miss overshoot
   Clark et al. 2009 (Neuron, PMC2658737):
   Near-miss that OVERSHOOTS then returns activates ventral
   putamen (Z=4.30) + anterior insula (Z=3.63) — same as wins
   Near-miss more motivating at 20-40% frequency (Barton 2017)
═══════════════════════════════════════════════════════════ */
.slot-hdr{font-size:7px;font-weight:800;letter-spacing:.2em;text-transform:uppercase;color:var(--t3);font-family:var(--m)}
.slot-wrap{display:flex;gap:7px;align-items:center;width:100%;justify-content:center}
.ssep{font-size:12px;color:var(--t3);font-weight:700;flex-shrink:0}

.sreel{
  flex:1;max-width:124px;position:relative;border-radius:10px;overflow:hidden;
  border:1px solid rgba(255,255,255,.08);height:240px;background:var(--s1);
  transition:border-color .4s,box-shadow .4s;
}
.sreel::before,.sreel::after{content:'';position:absolute;left:0;right:0;height:68px;z-index:3;pointer-events:none}
.sreel::before{top:0;background:linear-gradient(to bottom,var(--s1),transparent)}
.sreel::after{bottom:0;background:linear-gradient(to top,var(--s1),transparent)}
/* CS2 selection window */
.rl-t,.rl-b{position:absolute;left:0;right:0;height:1.5px;z-index:4;pointer-events:none;background:rgba(194,255,61,.25);transition:background .4s}
.rl-t{top:80px}.rl-b{bottom:80px}
/* CS2 diamond corner markers */
.rl-t::before,.rl-t::after,.rl-b::before,.rl-b::after{content:'';position:absolute;top:50%;width:7px;height:7px;background:rgba(194,255,61,.35);transform:translateY(-50%) rotate(45deg);transition:background .4s,box-shadow .4s}
.rl-t::before,.rl-b::before{left:-3.5px}.rl-t::after,.rl-b::after{right:-3.5px}
/* Lock states by rarity (CS2 color system) */
.sreel.lk-value{border-color:rgba(75,105,255,.55);box-shadow:0 0 22px rgba(75,105,255,.14)}
.sreel.lk-value .rl-t,.sreel.lk-value .rl-b{background:var(--blue)}
.sreel.lk-value .rl-t::before,.sreel.lk-value .rl-t::after,.sreel.lk-value .rl-b::before,.sreel.lk-value .rl-b::after{background:var(--blue);box-shadow:0 0 6px rgba(75,105,255,.6)}
.sreel.lk-high{border-color:rgba(211,44,230,.6);box-shadow:0 0 28px rgba(211,44,230,.18)}
.sreel.lk-high .rl-t,.sreel.lk-high .rl-b{background:var(--pink)}
.sreel.lk-high .rl-t::before,.sreel.lk-high .rl-t::after,.sreel.lk-high .rl-b::before,.sreel.lk-high .rl-b::after{background:var(--pink);box-shadow:0 0 8px rgba(211,44,230,.7)}
.sreel.lk-jackpot{animation:reelJP 1.8s linear infinite}
@keyframes reelJP{
  0%{border-color:rgba(255,215,0,.6);box-shadow:0 0 28px rgba(255,215,0,.16)}
  33%{border-color:rgba(239,51,64,.6);box-shadow:0 0 28px rgba(239,51,64,.14)}
  66%{border-color:rgba(211,44,230,.6);box-shadow:0 0 28px rgba(211,44,230,.14)}
  100%{border-color:rgba(255,215,0,.6);box-shadow:0 0 28px rgba(255,215,0,.16)}
}
.rtk{display:flex;flex-direction:column;will-change:transform}
.ritem{height:80px;flex-shrink:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:6px;gap:2px}
.ri-n{font-size:9px;font-weight:800;text-align:center;line-height:1.2;color:var(--t2)}
.ri-o{font-family:var(--m);font-size:15px;font-weight:700;color:var(--lime);line-height:1.2}
.ri-m{font-size:7px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.04em}

/* Slot total */
.slot-total{display:flex;flex-direction:column;align-items:center;gap:3px;opacity:0}
.st-lbl{font-size:7px;font-family:var(--m);font-weight:700;color:var(--t3);letter-spacing:.14em;text-transform:uppercase}
.st-val{font-family:var(--m);font-size:54px;font-weight:900;color:var(--lime);letter-spacing:-.05em;line-height:1;text-shadow:0 0 55px rgba(194,255,61,.42)}
.st-sub{font-size:9px;color:var(--t2);font-weight:700;letter-spacing:.04em}

/* ═══ FLIP CARDS — FIFA UT pack opening (Y-axis 3D transform) ═══ */
.flip-wrap{perspective:900px}
.flip-card{position:relative;width:100%;transform-style:preserve-3d;will-change:transform}
.flip-f,.flip-b{position:absolute;top:0;left:0;width:100%;border-radius:var(--r);backface-visibility:hidden;-webkit-backface-visibility:hidden}
.flip-f{height:136px;background:linear-gradient(135deg,var(--s1),var(--s2));border:1px solid var(--bd1);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:7px}
.ffi{width:46px;height:46px;border-radius:50%;border:1.5px solid var(--bd2);overflow:hidden;display:flex;align-items:center;justify-content:center;animation:fflt 2.8s ease infinite;position:relative}
.ffi img{width:28px;height:28px;object-fit:contain}
.ffi::after{content:'';position:absolute;inset:-8px;border-radius:50%;border:1px solid rgba(255,255,255,.055);animation:fspin 4s linear infinite}
@keyframes fflt{0%,100%{transform:translateY(0)}50%{transform:translateY(-4px)}}
@keyframes fspin{to{transform:rotate(360deg)}}
.fft{font-size:8px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:var(--t3)}
.flip-flash{position:absolute;inset:0;background:#fff;border-radius:var(--r);opacity:0;pointer-events:none;z-index:10}

/* ═══ SYSTEM BUILDER ═══ */
#s-system{background:var(--bg)}
.sbody{flex:1;display:flex;overflow:hidden}
.sl{flex:1;overflow-y:auto;padding:9px;display:flex;flex-direction:column;gap:7px;border-right:1px solid var(--bd1)}
.sl::-webkit-scrollbar{display:none}
.sr{width:262px;flex-shrink:0;display:flex;flex-direction:column}
@media(max-width:700px){.sbody{flex-direction:column}.sr{width:100%;border-top:1px solid var(--bd1);max-height:45vh}.sl{max-height:55vh}}
.sst{font-size:7px;font-weight:800;color:var(--t3);letter-spacing:.12em;text-transform:uppercase;margin-bottom:2px}
.mrow{border-radius:11px;border:1px solid var(--bd1);background:var(--s1);padding:10px 11px;display:flex;flex-direction:column;gap:7px;position:relative;overflow:hidden;transition:border-color var(--t-mid),background var(--t-mid)}
.mrow:hover{border-color:rgba(0,242,232,.18);background:var(--s2)}
.mrow.sel{border-color:rgba(0,242,232,.38);background:rgba(0,242,232,.04)}
.mrow.sel::before{content:'';position:absolute;top:0;left:0;width:2px;height:100%;background:var(--cyan)}
.mr-top{display:flex;align-items:center;gap:5px;font-size:11px;font-weight:800}
.mr-vs{color:var(--t3);font-size:9px;font-weight:400}
.mr-time{font-size:8px;font-family:var(--m);color:var(--t3);margin-left:auto}
.mr-mkts{display:flex;flex-direction:column;gap:5px}
.mr-mkt-row{display:flex;flex-direction:column;gap:3px}
.mr-mkt-lbl{font-size:7px;font-weight:800;color:var(--t3);letter-spacing:.1em;text-transform:uppercase;padding-left:1px}
.mr-btns{display:flex;gap:4px}
/* FanDuel/DraftKings authentic odds button */
.mrb{flex:1;padding:6px 4px;border-radius:7px;border:1px solid var(--bd1);background:var(--s2);display:flex;flex-direction:column;align-items:center;gap:1px;cursor:pointer;transition:all var(--t-fast);position:relative;overflow:hidden}
.mrb::before{content:'';position:absolute;inset:-1px;border-radius:8px;opacity:0;transition:opacity var(--t-fast)}
.mrb:hover::before{background:linear-gradient(135deg,rgba(194,255,61,.14),rgba(0,242,232,.09));opacity:1}
.mrb.a{border-color:rgba(0,242,232,.4);background:rgba(0,242,232,.055)}
.mrb-n{font-size:7px;color:var(--t3);font-weight:700;text-align:center;line-height:1.2}
.mrb-o{font-family:var(--m);font-size:13px;font-weight:700;color:var(--cyan);line-height:1.2}
.mrb-e{font-size:7px;font-weight:700;font-family:var(--m)}
.mrb-e.eg{color:var(--lime)}.mrb-e.eo{color:var(--gold)}.mrb-e.en{color:var(--t3)}
.mrb.mw:hover,.mrb.mw.a{border-color:rgba(194,255,61,.35);background:rgba(194,255,61,.048)}
.mrb.mw.a .mrb-o{color:var(--lime)}
.mrb.mh:hover,.mrb.mh.a{border-color:rgba(255,215,0,.35);background:rgba(255,215,0,.048)}
.mrb.mh.a .mrb-o{color:var(--gold)}
.mrb.mt:hover,.mrb.mt.a{border-color:rgba(155,93,229,.35);background:rgba(155,93,229,.048)}
.mrb.mt.a .mrb-o{color:var(--violet)}
.stray{flex:1;padding:9px;overflow-y:auto;display:flex;flex-direction:column;gap:5px}
.stray::-webkit-scrollbar{display:none}
.te{flex:1;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:5px;color:var(--t3);font-size:10px;font-weight:700;text-align:center}
.tei{font-size:18px;opacity:.18}
.titem{border-radius:8px;border:1px solid rgba(0,242,232,.17);background:rgba(0,242,232,.038);padding:7px 9px;display:flex;align-items:center;gap:6px}
.ti-n{font-size:11px;font-weight:800;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ti-m{font-size:8px;color:var(--t3);font-weight:700;flex-shrink:0}
.ti-o{font-family:var(--m);font-size:12px;font-weight:700;color:var(--cyan);flex-shrink:0}
.ti-rm{width:15px;height:15px;border-radius:4px;background:rgba(239,51,64,.1);color:var(--red);display:flex;align-items:center;justify-content:center;font-size:7px;cursor:pointer;transition:background var(--t-fast);flex-shrink:0}
.ti-rm:hover{background:rgba(239,51,64,.2)}
.sfoot{padding:9px 11px;border-top:1px solid var(--bd1);display:flex;flex-direction:column;gap:6px}
.sfr{display:flex;justify-content:space-between;align-items:center}
.sfl{font-size:8px;color:var(--t3);font-weight:700;text-transform:uppercase;letter-spacing:.06em}
.sfv{font-family:var(--m);font-size:12px;font-weight:700;color:var(--t1)}
.sfv.li{color:var(--lime)}
.sfbig{font-family:var(--m);font-size:26px;font-weight:900;color:var(--cyan);letter-spacing:-.04em;line-height:1}
.sfbs{font-size:7px;color:var(--t3);text-transform:uppercase;letter-spacing:.08em}
#btn-sys{width:100%;height:44px;border-radius:10px;border:none;font-size:12px;font-weight:900;letter-spacing:.06em;text-transform:uppercase;background:var(--cyan);color:#000;opacity:.3;pointer-events:none;transition:opacity .3s,transform var(--t-snap)}
#btn-sys.rdy{opacity:1;pointer-events:all;animation:cP 2.4s ease infinite}
@keyframes cP{0%,100%{box-shadow:0 0 0 0 rgba(0,242,232,.5)}55%{box-shadow:0 0 0 16px rgba(0,242,232,0)}}
#btn-sys:active{transform:scale(.96)}

/* ═══ TOAST ═══ */
#ta{position:fixed;bottom:80px;left:50%;transform:translateX(-50%);z-index:200;display:flex;flex-direction:column;gap:4px;align-items:center;pointer-events:none;width:calc(100% - 24px);max-width:390px}
.tm{padding:7px 14px;border-radius:var(--r-full);font-size:10px;font-weight:800;background:rgba(5,5,15,.97);border:1px solid var(--bd2);backdrop-filter:blur(20px);animation:tIn var(--t-fast) var(--ease-out) both;white-space:nowrap;max-width:100%;overflow:hidden;text-overflow:ellipsis;text-align:center}
@keyframes tIn{from{transform:translateY(10px);opacity:0}to{transform:translateY(0);opacity:1}}
.tm.lime{border-color:rgba(194,255,61,.28);color:var(--lime)}
.tm.gold{border-color:rgba(255,215,0,.28);color:var(--gold)}
.tm.pink{border-color:rgba(211,44,230,.28);color:var(--pink)}
</style>
</head>
<body>
<canvas id="bg"></canvas>
<canvas id="pc"></canvas>

<!-- HOME -->
<div class="screen" id="s-home">
  <div class="hero-bg"></div>
  <div class="logo-pill"><div class="ldot"></div>betatp.io<div class="lpill-badge">v14</div></div>
  <div class="hero-center">
    <h1 class="hero-t" id="ht">betatp</h1>
    <p class="hero-sub" id="hs">LightGBM v14 &nbsp;&middot;&nbsp; AUC&nbsp;0.9031 &nbsp;&middot;&nbsp; ROI&nbsp;+42.1%</p>
    <div class="market-row">
      <div class="mc l">🏆 Winner</div>
      <div class="mc c">1️⃣ First Set</div>
      <div class="mc g">± Handicap</div>
      <div class="mc v">∑ Total Sets</div>
      <div class="mc b">⚡ Score</div>
    </div>
  </div>
  <div class="deck">
    <div class="hcard hcard-d" id="c-daily">
      <div class="hfoil"></div><div class="hglare"></div><div class="hbrd"></div>
      <div class="hcard-in">
        <div class="hcico"><img src="https://v3b.fal.media/files/b/0a9fe17c/5aXGKPrN0YKu8ZD2fKCcS_UD57jLsn.png" alt=""></div>
        <h2 class="hctitle">Daily Kupon</h2>
        <p class="hcdesc">AI dobiera 3 picks z 5 rynkow. CS:GO ceremony. Model v14 z logika decyzji.</p>
        <div class="hctag">AI GENERATED</div>
      </div>
    </div>
    <div class="hcard hcard-s" id="c-system">
      <div class="hfoil"></div><div class="hglare"></div><div class="hbrd"></div>
      <div class="hcard-in">
        <div class="hcico"><img src="https://v3b.fal.media/files/b/0a9fe199/Du0tghwLqy4Iok3ECgYmt_9Jud0sAW.png" alt=""></div>
        <h2 class="hctitle">Graj Systemem</h2>
        <p class="hcdesc">3 rynki na mecz. Kelly live. Akumulator mieszany z edge score.</p>
        <div class="hctag">SYSTEM BUILDER</div>
      </div>
    </div>
  </div>
  <!-- Social proof ticker — Cialdini 1984 + availability heuristic (Clark 2012) -->
  <div class="sp-ticker">
    <div class="sp-inner" id="sp-inner">
      <div class="sp-item">Backtest 57 betow <span class="sp-v">+42.1% ROI</span></div>
      <div class="sp-sep">·</div>
      <div class="sp-item">Fritz @ 2.80 <span class="sp-g">Edge +31.6%</span></div>
      <div class="sp-sep">·</div>
      <div class="sp-item">Norrie +1.5 @ 1.78 <span class="sp-g">Edge +21.1%</span></div>
      <div class="sp-sep">·</div>
      <div class="sp-item">AUC model v14 <span class="sp-v">0.9031</span></div>
      <div class="sp-sep">·</div>
      <div class="sp-item">Wimbledon 2026 <span class="sp-v">3 value picks dzis</span></div>
      <div class="sp-sep">·</div>
      <div class="sp-item">Kelly sizing <span class="sp-g">+38% avg edge</span></div>
      <div class="sp-sep">·</div>
      <!-- duplicate for seamless loop -->
      <div class="sp-item">Backtest 57 betow <span class="sp-v">+42.1% ROI</span></div>
      <div class="sp-sep">·</div>
      <div class="sp-item">Fritz @ 2.80 <span class="sp-g">Edge +31.6%</span></div>
      <div class="sp-sep">·</div>
      <div class="sp-item">Norrie +1.5 @ 1.78 <span class="sp-g">Edge +21.1%</span></div>
      <div class="sp-sep">·</div>
      <div class="sp-item">AUC model v14 <span class="sp-v">0.9031</span></div>
      <div class="sp-sep">·</div>
      <div class="sp-item">Wimbledon 2026 <span class="sp-v">3 value picks dzis</span></div>
      <div class="sp-sep">·</div>
      <div class="sp-item">Kelly sizing <span class="sp-g">+38% avg edge</span></div>
      <div class="sp-sep">·</div>
    </div>
  </div>
</div>

<!-- OVERLAY -->
<div id="ov">
  <div class="ov-bg"></div>
  <div class="ov-scanlines"></div>
  <div class="ovp" id="ovp1">
    <div class="ovtag">model v14 · 5 rynkow · wimbledon 2026</div>
